{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2024", //ESM
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist"
  },
  "include": ["src"]
}
